# Ghostwire Proxy Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# Application
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL Database
POSTGRES_DB=ghostwire_proxy
POSTGRES_USER=ghostwire
POSTGRES_PASSWORD=your-secure-password-change-this

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (for storing sensitive data like OAuth secrets)
ENCRYPTION_KEY=your-encryption-key-32-chars-min

# CORS — comma-separated list of allowed origins
# For local dev: http://localhost:88
# For LAN access: http://192.168.x.x:88,http://192.168.x.x:8089
CORS_ORIGINS=http://localhost:88,http://localhost:3000

# Admin UI (Next.js)
NEXTAUTH_SECRET=your-nextauth-secret-change-this
#
# NEXTAUTH_URL controls how you access the admin panel:
#   IP/localhost  → direct access on port 88 (e.g. http://localhost:88)
#   FQDN          → auto-creates a proxy host + Let's Encrypt SSL cert on first startup
#                   (e.g. https://proxy.example.com — requires DNS pointing to this server)
#
NEXTAUTH_URL=http://localhost:88

# Internal auth token (Lua ↔ API communication)
INTERNAL_AUTH_TOKEN=generate-a-random-hex-string

# Let's Encrypt (required if NEXTAUTH_URL uses an FQDN)
LETSENCRYPT_EMAIL=admin@example.com

# Web Push notifications (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
