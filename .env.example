# Ghostwire Proxy Environment Configuration

# Application
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL Database
POSTGRES_DB=ghostwire_proxy
POSTGRES_USER=ghostwire
POSTGRES_PASSWORD=your-secure-password-change-this

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (for storing sensitive data like OAuth secrets)
ENCRYPTION_KEY=your-encryption-key-32-chars-min

# CORS
CORS_ORIGINS=http://localhost:88,http://localhost:3000

# Admin UI (Next.js)
NEXTAUTH_SECRET=your-nextauth-secret-change-this
NEXTAUTH_URL=http://localhost:88
NEXT_PUBLIC_API_URL=http://localhost:8089

# Let's Encrypt
LETSENCRYPT_EMAIL=admin@example.com

# Optional: Ghostwire Integration
GHOSTWIRE_API_URL=
GHOSTWIRE_API_KEY=

# Optional: Elasticsearch for traffic logs
ELASTICSEARCH_URL=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
